# --- STOCKINTEL TERMINAL CONFIGURATION ---

# 1. DATABASE CONFIGURATION
# Format: mysql+pymysql://user:password@host:port/dbname
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/stock_tracker
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=stock_tracker

# 2. AI & INTELLIGENCE (REQUIRED)
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# 3. TELEGRAM NOTIFICATIONS (OPTIONAL)
# Create a bot via @BotFather to get the Token
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get your Chat ID via @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# 4. EMAIL NOTIFICATIONS (OPTIONAL)
# Use a Gmail App Password (not your account password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# 5. SECURITY & AUTH
# Generate a strong secret key for JWT
JWT_SECRET=your_jwt_secret_here
SECRET_KEY=your_flask_secret_key_here

# 6. APP SETTINGS
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000
